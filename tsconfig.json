{
  "compilerOptions": {
    "allowJs": false,
    "jsx": "react-native",
    "lib": ["dom", "esnext"],
    "moduleResolution": "node",
    "noEmit": true,
    "isolatedModules": true,
    "strict": true,
    "resolveJsonModule": true,
  "types": ["jest", "react", "react-native", "node"],
    "target": "esnext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "App.tsx", "__tests__", "jest-setup.ts"],
  "exclude": ["node_modules"]
}
